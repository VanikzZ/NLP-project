# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Choose one LLM provider: Mistral, OpenRouter Qwen, OpenAI
DEFAULT_LLM_PROVIDER=OpenAI

# Optional override. If empty, each provider uses its own default model.
DEFAULT_LLM_MODEL=

# OpenAI API key from https://platform.openai.com/api-keys
# Important: ChatGPT Plus subscription is separate from OpenAI API billing.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=NLP mini-project bot

# Mistral
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest
